@app.route('/student-stats', methods=['GET'])
def student_stats():
    from sqlalchemy import func
    results = db.session.query(
        Student.risk_level, 
        func.count(Student.id)
    ).group_by(Student.risk_level).all()
    
    stats = {
        "total_students": 0,
        "high_risk_count": 0,
        "low_risk_count": 0,
        "medium_risk_count": 0
    }
    
    for risk, count in results:
        stats["total_students"] += count
        if risk == 'HIGH': stats["high_risk_count"] = count
        elif risk == 'LOW': stats["low_risk_count"] = count
        elif risk == 'MEDIUM': stats["medium_risk_count"] = count
        
    return jsonify(stats), 200

@app.route('/login', methods=['POST'])
def login():
    data = request.get_json()
    if not data:
        return jsonify({"message": "No input data provided"}), 400

    role = data.get('role', 'Admin')
    school_code = data.get('school_code', '').strip()
    password = data.get('password', '').strip()
    
    print(f"DEBUG: Login Attempt - Role: {role}, School: {school_code}")

    user = None
    # Selection based on role
    if role == 'Admin':
        email = data.get('email', '').strip()
        print(f"DEBUG: Admin Log - Email: {email}")
        if not all([school_code, email, password]):
            return jsonify({"message": "Please enter school code, email and password"}), 400
        user = User.query.filter_by(email=email, school_code=school_code, role='Admin').first()

    elif role == 'Teacher':
        email = data.get('email', '').strip()
        print(f"DEBUG: Teacher Log - Email: '{email}', Pwd: '{password}'")
        if not all([email, password]):
            return jsonify({"message": "Please enter email and password"}), 400
            
        user = Teacher.query.filter_by(email=email, password=password).first()
        if not user:
            # Fallback check: trace if email exists at all
            exists = Teacher.query.filter_by(email=email).first()
            if exists:
                print(f"DEBUG: Teacher email exists but password mismatch: '{exists.password}' vs '{password}'")
            else:
                print(f"DEBUG: Teacher email '{email}' NOT found in database")
            return jsonify({"message": "Invalid email or password"}), 401

    elif role == 'Parent':
        roll_no = data.get('roll_no')
        print(f"DEBUG: Parent RollNo: {roll_no}")
        if not all([school_code, roll_no, password]):
            return jsonify({"message": "Please enter school code, Roll No and password"}), 400
        user = User.query.filter_by(roll_no=roll_no, school_code=school_code, role='Parent').first()
    
    else:
        return jsonify({"message": "Invalid role specified"}), 400

    if user and user.password == password:
        return jsonify({
            "message": "Login successful",
            "user": {
                "full_name": user.full_name if hasattr(user, 'full_name') else user.name,
                "role": role,
                "class_assigned": user.class_assigned if hasattr(user, 'class_assigned') else None
            }
        }), 200
    else:
        return jsonify({"message": "Invalid credentials"}), 401

# ── Teacher Management ──────────────────────────────────────────────────────

@app.route('/add-teacher', methods=['POST'])
def add_teacher():
    data = request.get_json()
    if not data:
        return jsonify({"message": "No data provided"}), 400
    
    new_teacher = Teacher(
        name=data.get('name'),
        subject=data.get('subject'),
        phone=data.get('phone'),
        class_assigned=data.get('class_assigned'),
        school_code=data.get('school_code', 'SCH123'),
        status='PENDING'
    )
    
    try:
        db.session.add(new_teacher)
        db.session.commit()
        return jsonify({"message": "Teacher registered for approval!"}), 201
    except Exception as e:
        db.session.rollback()
        return jsonify({"message": str(e)}), 500

@app.route('/get-teachers', methods=['GET'])
def get_teachers():
    teachers = Teacher.query.all()
    output = []
    for t in teachers:
        output.append({
            "id": t.id,
            "name": t.name,
            "email": t.email,
            "subject": t.subject,
            "phone": t.phone,
            "class_assigned": t.class_assigned,
            "status": t.status
        })
    return jsonify(output), 200

@app.route('/update-teacher-status', methods=['POST'])
def update_teacher_status():
    data = request.get_json()
    teacher_id = data.get('id')
    new_status = data.get('status')
    
    teacher = Teacher.query.get(teacher_id)
    if not teacher:
        return jsonify({"message": "Teacher not found"}), 404
    
    teacher.status = new_status
    
    # If approved, set credentials
    if new_status == 'APPROVED':
        email = data.get('email')
        password = data.get('password')
        if not email or not password:
            return jsonify({"message": "Email and password are required for approval"}), 400
        teacher.email = email
        teacher.password = password
    
    try:
        db.session.commit()
        return jsonify({"message": f"Teacher {new_status.lower()} successfully"}), 200
    except Exception as e:
        db.session.rollback()
        return jsonify({"message": str(e)}), 500

# ── Dashboard Insights ──────────────────────────────────────────────────────

@app.route('/recent-high-risk', methods=['GET'])
def recent_high_risk():
    high_risk_students = Student.query.filter_by(risk_level='HIGH').order_by(Student.created_at.desc()).limit(3).all()
    output = []
    for s in high_risk_students:
        output.append({
            "name": s.name,
            "class_name": s.class_name,
            "attendance": f"{s.attendance_percentage}%"
        })
    return jsonify(output), 200

# ── Admin Profile Endpoints ─────────────────────────────────────────────────

@app.route('/get-admin-profile', methods=['GET'])
def get_admin_profile():
    email = request.args.get('email')
    if not email:
        return jsonify({"message": "Email is required"}), 400
    
    profile = AdminProfile.query.filter_by(email=email).first()
    if not profile:
        # Fallback: check if User exists and create profile if missing
        user = User.query.filter_by(email=email, role='Admin').first()
        if user:
            profile = AdminProfile(name=user.full_name, email=user.email)
            db.session.add(profile)
            db.session.commit()
        else:
            return jsonify({"message": "Admin profile not found"}), 404
            
    return jsonify({
        "name": profile.name,
        "email": profile.email,
        "phone": profile.phone,
        "role": profile.role,
        "school": profile.school,
        "state": profile.state
    }), 200

@app.route('/update-admin-profile', methods=['POST'])
def update_admin_profile():
    data = request.get_json()
    email = data.get('email')
    if not email:
        return jsonify({"message": "Email is required"}), 400
        
    profile = AdminProfile.query.filter_by(email=email).first()
    if not profile:
        return jsonify({"message": "Admin profile not found"}), 404
        
    # Only update allowed fields
    profile.phone = data.get('phone', profile.phone)
    profile.school = data.get('school', profile.school)
    profile.state = data.get('state', profile.state)
    
    try:
        db.session.commit()
        return jsonify({"message": "Profile updated successfully!"}), 200
    except Exception as e:
        db.session.rollback()
        return jsonify({"message": str(e)}), 500

@app.route('/change-password', methods=['POST'])
def change_password():
    data = request.get_json()
    email = data.get('email')
    current_password = data.get('current_password')
    new_password = data.get('new_password')
    
    if not all([email, current_password, new_password]):
        return jsonify({"message": "Missing required fields"}), 400
        
    user = User.query.filter_by(email=email, role='Admin').first()
    if not user:
        return jsonify({"message": "Admin user not found"}), 404
        
    if user.password != current_password:
        return jsonify({"message": "Incorrect current password"}), 401
        
    user.password = new_password
    try:
        db.session.commit()
        return jsonify({"message": "Password updated successfully"}), 200
    except Exception as e:
        db.session.rollback()
        return jsonify({"message": str(e)}), 500

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
